# --- Required for Supabase (server APIs) ---
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Auth ---
JWT_SECRET=generate-a-strong-random-string

# --- Encryption for SES credentials (recommended) ---
SES_ENCRYPTION_SECRET=generate-a-strong-random-string

# --- Cron protection ---
CRON_SECRET=generate-a-strong-random-string

# --- Optional (UI or other features) ---
NEXT_PUBLIC_APP_URL=https://your-app-url
NEXT_PUBLIC_TRACKING_DOMAIN=https://your-tracking-domain

# --- Stripe (existing billing) ---
STRIPE_SECRET_KEY=sk_xxx
STRIPE_PUBLISHABLE_KEY=pk_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Resend transactional (optional) ---
RESEND_API_KEY=re_xxx
RESEND_SENDING_DOMAIN=sender@yourdomain.com
RESEND_WEBHOOK_SECRET=whsec_xxx

# --- OpenAI for AI reply classification ---
OPENAI_API_KEY=sk-xxx

# --- Email webhook protection ---
EMAIL_WEBHOOK_SECRET=generate-a-strong-random-string
